# Sponsor Matching Agent — Environment Variables
# Copy this file to .env and fill in your values

AZURE_AI_FOUNDRY_ENDPOINT=https://<your-project>.services.ai.azure.com/api/projects/<your-project>_project
AZURE_AI_FOUNDRY_API_KEY=<your-api-key>
AZURE_AI_MODEL=gpt-4o-mini
AZURE_AI_SPONSOR_MATCHING_AGENT_ID=<your-sponsor-matching-agent-id>
