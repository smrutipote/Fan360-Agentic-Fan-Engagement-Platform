# Fan360 Orchestrator — Environment Variables
# Copy this file to .env and fill in your values

# ── Azure AI Foundry ───────────────────────────────────────────
AZURE_AI_FOUNDRY_ENDPOINT=https://<your-project>.services.ai.azure.com/api/projects/<your-project>_project
AZURE_AI_FOUNDRY_API_KEY=<your-api-key>
AZURE_AI_AGENT_ID=<your-orchestrator-agent-id>
AZURE_AI_MODEL=gpt-4o-mini

# ── MCP / DAB ──────────────────────────────────────────────────
MCP_BASE_URL=http://localhost:5000/mcp

# ── Microsoft Fabric (OneLake write-back) ──────────────────────
FABRIC_WORKSPACE_ID=<your-fabric-workspace-guid>
FABRIC_LAKEHOUSE_ID=<your-fabric-lakehouse-guid>

# ── Gmail SMTP (birthday emails) ──────────────────────────────
GMAIL_SENDER=<your-email@gmail.com>
GMAIL_APP_PASSWORD=<your-gmail-app-password>
